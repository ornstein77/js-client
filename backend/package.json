{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.env --watch run index.ts",
    "build": "bun build index.ts --outdir ./dist --target bun",
    "start": "bun --env-file=.env run dist/index.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/pg": "latest",
    "prisma": "latest",
    "typescript": "latest"
  }
}
